<Window x:Class="PenumbraOrganizer.App.ExportPackageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI review package created"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <StackPanel Margin="20" Width="480">
        <TextBlock Text="Upload Penumbra_AI_Review_Package.zip to your AI assistant, then paste the master prompt."
                   TextWrapping="Wrap"
                   Margin="0,0,0,16" />
        <WrapPanel>
            <Button Content="Open Export Folder" Click="OpenExportFolder_Click" MinWidth="130" Height="32" Margin="0,0,8,8" />
            <Button Content="Copy Prompt" Click="CopyPrompt_Click" MinWidth="110" Height="32" Margin="0,0,8,8" />
            <Button Content="Copy Inventory Path" Click="CopyInventoryPath_Click" MinWidth="130" Height="32" Margin="0,0,8,8" />
            <Button Content="Done" Click="Done_Click" MinWidth="90" Height="32" Margin="0,0,8,8" />
        </WrapPanel>
    </StackPanel>
</Window>

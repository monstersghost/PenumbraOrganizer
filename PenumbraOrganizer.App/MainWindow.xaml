<Window x:Class="PenumbraOrganizer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:behaviors="clr-namespace:PenumbraOrganizer.App.Behaviors"
        mc:Ignorable="d"
        Title="Penumbra Organizer"
        Height="860"
        Width="1380"
        MinHeight="740"
        MinWidth="1180"
        WindowStartupLocation="CenterScreen"
        Background="#FFF4F6F8">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#FFD9DFE7"
                BorderThickness="0,0,0,1"
                Padding="24,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Penumbra Organizer"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="#FF1C2633" />
                    <TextBlock Margin="0,6,0,0"
                               Text="Portable organizer for Penumbra virtual folders. Physical mod files stay exactly where they are."
                               Foreground="#FF556171"
                               TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Command="{Binding DetectCommand}"
                            Content="Find Penumbra"
                            MinWidth="125"
                            Height="36"
                            Margin="0,0,10,0" />
                    <Button Command="{Binding ScanCommand}"
                            Content="Scan My Mods"
                            MinWidth="130"
                            Height="36" />
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1"
                    Margin="20"
                    IsEnabled="{Binding IsNotBusy}">
            <TabItem Header="Home / Scan">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Row="0"
                                Grid.Column="0"
                                Background="White"
                                BorderBrush="#FFD9DFE7"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="20">
                            <StackPanel>
                                <TextBlock Text="Ready to Scan"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           Foreground="#FF1C2633" />
                                <TextBlock Margin="0,12,0,0"
                                           Text="{Binding DetectionSummary}"
                                           FontSize="16"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,10,0,0"
                                           Text="{Binding CompatibilitySummary}"
                                           Foreground="#FF556171"
                                           TextWrapping="Wrap" />
                                <WrapPanel Margin="0,18,0,0">
                                    <Button Command="{Binding ScanCommand}"
                                            Content="Scan My Mods"
                                            MinWidth="150"
                                            Height="40"
                                            Margin="0,0,10,10"
                                            FontWeight="SemiBold" />
                                    <Button Command="{Binding DetectCommand}"
                                            Content="Find Penumbra Again"
                                            MinWidth="150"
                                            Height="40"
                                            Margin="0,0,10,10" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="0"
                                Grid.Column="2"
                                Background="White"
                                BorderBrush="#FFD9DFE7"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="20">
                            <StackPanel>
                                <TextBlock Text="Detected Paths"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Margin="0,12,0,0"
                                           Text="Penumbra state directory"
                                           Foreground="#FF556171" />
                                <TextBlock Text="{Binding PenumbraStateDirectory}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,12,0,0"
                                           Text="Mod library root"
                                           Foreground="#FF556171" />
                                <TextBlock Text="{Binding ModLibraryRoot}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,12,0,0"
                                           Text="Installed Penumbra version"
                                           Foreground="#FF556171" />
                                <TextBlock Text="{Binding InstalledPenumbraVersion}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1"
                                Grid.ColumnSpan="3"
                                Margin="0,18,0,0"
                                Background="#FFFDF6E7"
                                BorderBrush="#FFE9D5A1"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18"
                                Visibility="{Binding InstallationMissing, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="Automatic detection did not find Penumbra."
                                           FontWeight="SemiBold"
                                           Foreground="#FF7A5312" />
                                <TextBlock Margin="0,6,0,0"
                                           Text="Choose your Penumbra.json file manually if XIVLauncher is stored somewhere unusual."
                                           TextWrapping="Wrap" />
                                <WrapPanel Margin="0,14,0,0">
                                    <Button Command="{Binding ChoosePenumbraConfigCommand}"
                                            Content="Choose Penumbra.json"
                                            MinWidth="180"
                                            Height="36"
                                            Margin="0,0,10,0" />
                                    <TextBlock VerticalAlignment="Center"
                                               Text="{Binding ManualConfigPath}"
                                               Foreground="#FF556171"
                                               TextWrapping="Wrap" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="2"
                              Grid.ColumnSpan="3"
                              Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="White"
                                    BorderBrush="#FFD9DFE7"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="18">
                                <StackPanel>
                                    <TextBlock Text="Installed mods"
                                               Foreground="#FF556171" />
                                    <TextBlock Text="{Binding InstalledModCount}"
                                               FontSize="28"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Background="White"
                                    BorderBrush="#FFD9DFE7"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="18">
                                <StackPanel>
                                    <TextBlock Text="Protected mods"
                                               Foreground="#FF556171" />
                                    <TextBlock Text="{Binding ProtectedModCount}"
                                               FontSize="28"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="4"
                                    Background="White"
                                    BorderBrush="#FFD9DFE7"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="18">
                                <StackPanel>
                                    <TextBlock Text="Collections / warnings"
                                               Foreground="#FF556171" />
                                    <TextBlock FontSize="28"
                                               FontWeight="SemiBold">
                                        <Run Text="{Binding CollectionCount, Mode=OneWay}" />
                                        <Run Text=" / " />
                                        <Run Text="{Binding WarningCount, Mode=OneWay}" />
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Grid.Row="3"
                                Grid.ColumnSpan="3"
                                Margin="0,18,0,0"
                                Background="White"
                                BorderBrush="#FFD9DFE7"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Scan Warnings"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <ListBox Grid.Row="1"
                                         Margin="0,12,0,0"
                                         ItemsSource="{Binding ScanWarnings}"
                                         MinHeight="220" />
                            </Grid>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Workbook Workflow">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="White"
                                BorderBrush="#FFD9DFE7"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Simple workbook flow"
                                               FontSize="20"
                                               FontWeight="SemiBold" />
                                    <TextBlock Margin="0,10,0,0"
                                               Text="Scan your library, export one workbook, edit only the destination and protected columns, import it back, review the diff, then click Backup and Apply."
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,10,0,0"
                                               Text="{Binding WorkbookStatus}"
                                               Foreground="#FF556171"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding WorkbookImportStatus}"
                                               Foreground="#FF245C9A"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <WrapPanel Grid.Column="1"
                                           VerticalAlignment="Top">
                                    <Button Command="{Binding ExportWorkbookCommand}"
                                            Content="Export Workbook"
                                            MinWidth="150"
                                            Height="38"
                                            Margin="0,0,10,10"
                                            FontWeight="SemiBold" />
                                    <Button Command="{Binding OpenWorkbookCommand}"
                                            Content="Open Workbook"
                                            MinWidth="140"
                                            Height="38"
                                            Margin="0,0,10,10" />
                                    <Button Command="{Binding ImportWorkbookCommand}"
                                            Content="Import Workbook"
                                            MinWidth="150"
                                            Height="38" />
                                </WrapPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1"
                                Margin="0,16,0,0"
                                Background="White"
                                BorderBrush="#FFD9DFE7"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18">
                            <StackPanel>
                                <TextBlock Text="Recommendation Style"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Margin="0,8,0,0"
                                           Text="This only fills the initial destination values in the workbook. You can edit every destination before importing."
                                           TextWrapping="Wrap"
                                           Foreground="#FF556171" />
                                <WrapPanel Margin="0,14,0,0">
                                    <Button Command="{Binding SelectStrategyCommand}" CommandParameter="Start Manually" Content="Start manually" MinWidth="140" Height="34" Margin="0,0,10,10" />
                                    <Button Command="{Binding SelectStrategyCommand}" CommandParameter="By creator" Content="By creator" MinWidth="120" Height="34" Margin="0,0,10,10" />
                                    <Button Command="{Binding SelectStrategyCommand}" CommandParameter="By mod type" Content="By mod type" MinWidth="120" Height="34" Margin="0,0,10,10" />
                                    <Button Command="{Binding SelectStrategyCommand}" CommandParameter="By type and creator" Content="Type / author" MinWidth="135" Height="34" Margin="0,0,10,10" />
                                    <Button Command="{Binding SelectStrategyCommand}" CommandParameter="By creator and type" Content="Author / type" MinWidth="135" Height="34" Margin="0,0,10,10" />
                                    <Button Command="{Binding SelectStrategyCommand}" CommandParameter="Keep my current layout and clean it" Content="Preserve current" MinWidth="145" Height="34" Margin="0,0,10,10" />
                                </WrapPanel>
                                <TextBlock Margin="0,8,0,0"
                                           Text="{Binding SelectedStrategy, StringFormat=Selected strategy: {0}}"
                                           Foreground="#FF556171" />
                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="2"
                              Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="White"
                                    BorderBrush="#FFD9DFE7"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="18">
                                <StackPanel>
                                    <TextBlock Text="Workbook Columns"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock Margin="0,12,0,0"
                                               Text="id | mod name | author | current folder | detected type | protected | destination"
                                               FontFamily="Consolas"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,12,0,0"
                                               Text="Blank destination rule: leave destination empty to keep the current folder unchanged."
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,12,0,0"
                                               Text="Stable id matching is used on import. Names, author labels, and folder text are not used as keys."
                                               TextWrapping="Wrap"
                                               Foreground="#FF556171" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Background="White"
                                    BorderBrush="#FFD9DFE7"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="18">
                                <StackPanel>
                                    <TextBlock Text="Category Shorthand"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock Margin="0,12,0,0"
                                               Text="{Binding WorkbookCategorySummary}"
                                               FontFamily="Consolas"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,12,0,0"
                                               Text="Example: 1/Bizu becomes Clothing/Bizu. Safe relative paths like Bizu/1 are also allowed."
                                               TextWrapping="Wrap"
                                               Foreground="#FF556171" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Grid.Row="3"
                                Margin="0,16,0,0"
                                Background="White"
                                BorderBrush="#FFD9DFE7"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18">
                            <StackPanel>
                                <TextBlock Text="What happens on import"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Margin="0,12,0,0"
                                           Text="The app validates duplicate ids, unknown ids, malformed paths, traversal such as ../, and stale exports before updating the review list."
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,10,0,0"
                                           Text="After a successful import, go to Review Changes to inspect the diff. Backup and Apply still creates a fresh verified backup immediately before writing."
                                           TextWrapping="Wrap"
                                           Foreground="#FF556171" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Organize"
                     Visibility="{Binding ShowAdvancedTools, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="White"
                            BorderBrush="#FFD9DFE7"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="18">
                        <StackPanel>
                            <TextBlock Text="Choose how to organize your mods"
                                       FontSize="20"
                                       FontWeight="SemiBold" />
                            <WrapPanel Margin="0,14,0,0">
                                <Button Command="{Binding SelectStrategyCommand}" CommandParameter="Start Manually" Content="Start manually" MinWidth="140" Height="34" Margin="0,0,10,10" />
                                <Button Command="{Binding SelectStrategyCommand}" CommandParameter="By creator" Content="By creator" MinWidth="120" Height="34" Margin="0,0,10,10" />
                                <Button Command="{Binding SelectStrategyCommand}" CommandParameter="By mod type" Content="By mod type" MinWidth="120" Height="34" Margin="0,0,10,10" />
                                <Button Command="{Binding SelectStrategyCommand}" CommandParameter="By type and creator" Content="Type then creator" MinWidth="145" Height="34" Margin="0,0,10,10" />
                                <Button Command="{Binding SelectStrategyCommand}" CommandParameter="By creator and type" Content="Creator then type" MinWidth="145" Height="34" Margin="0,0,10,10" />
                                <Button Command="{Binding SelectStrategyCommand}" CommandParameter="Keep my current layout and clean it" Content="Preserve and clean" MinWidth="145" Height="34" Margin="0,0,10,10" />
                                <Button Command="{Binding SelectStrategyCommand}" CommandParameter="Custom" Content="Custom" MinWidth="110" Height="34" Margin="0,0,10,10" />
                                <Button Command="{Binding CreateAiReviewPackageCommand}" Content="Export inventory for AI" MinWidth="160" Height="34" Margin="0,0,10,10" />
                                <Button Command="{Binding ImportAiProposalCommand}" Content="Import AI proposal" MinWidth="145" Height="34" Margin="0,0,10,10" />
                            </WrapPanel>
                            <TextBlock Margin="0,10,0,0"
                                       Text="{Binding SelectedStrategy, StringFormat=Selected strategy: {0}}"
                                       Foreground="#FF556171" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Margin="0,16,0,0"
                            Background="White"
                            BorderBrush="#FFD9DFE7"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Height="34"
                                     Padding="10,6"
                                     VerticalContentAlignment="Center" />
                            <Button Grid.Column="1"
                                    Command="{Binding SetOrganizeFilterCommand}"
                                    CommandParameter="All Mods"
                                    Content="All Mods"
                                    MinWidth="90"
                                    Height="34"
                                    Margin="10,0,0,0" />
                            <Button Grid.Column="2"
                                    Command="{Binding SetOrganizeFilterCommand}"
                                    CommandParameter="Changed"
                                    Content="Changed"
                                    MinWidth="90"
                                    Height="34"
                                    Margin="10,0,0,0" />
                            <Button Grid.Column="3"
                                    Command="{Binding SetOrganizeFilterCommand}"
                                    CommandParameter="Needs Review"
                                    Content="Needs Review"
                                    MinWidth="110"
                                    Height="34"
                                    Margin="10,0,0,0" />
                            <TextBlock Grid.Column="4"
                                       Margin="16,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="#FF556171">
                                <Run Text="{Binding ChangedProposalCount, Mode=OneWay}" />
                                <Run Text=" changed, " />
                                <Run Text="{Binding NeedsReviewCount, Mode=OneWay}" />
                                <Run Text=" need review" />
                            </TextBlock>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2"
                          Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="330" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="330" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="White"
                                BorderBrush="#FFD9DFE7"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Current folder tree"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <DataGrid Grid.Row="1"
                                          Margin="0,12,0,0"
                                          ItemsSource="{Binding FolderTree}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserAddRows="False"
                                          HeadersVisibility="Column"
                                          SelectionMode="Single">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Current folder" Binding="{Binding Path}" Width="*" />
                                        <DataGridTextColumn Header="Mods" Binding="{Binding DirectModCount}" Width="70" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2"
                                Background="White"
                                BorderBrush="#FFD9DFE7"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Proposed folder tree"
                                           FontSize="18"
                                           FontWeight="SemiBold" />

                                <Grid Grid.Row="1"
                                      Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding NewFolderName, UpdateSourceTrigger=PropertyChanged}"
                                             Height="32"
                                             Padding="8,4"
                                             VerticalContentAlignment="Center" />
                                    <Button Grid.Column="1"
                                            Command="{Binding CreateProposedFolderCommand}"
                                            Content="Create Folder"
                                            MinWidth="110"
                                            Height="32"
                                            Margin="10,0,0,0" />
                                </Grid>

                                <Grid Grid.Row="2"
                                      Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding RenameFolderName, UpdateSourceTrigger=PropertyChanged}"
                                             Height="32"
                                             Padding="8,4"
                                             VerticalContentAlignment="Center" />
                                    <Button Grid.Column="1"
                                            Command="{Binding RenameFolderCommand}"
                                            Content="Rename"
                                            MinWidth="90"
                                            Height="32"
                                            Margin="10,0,0,0" />
                                </Grid>

                                <DataGrid Grid.Row="3"
                                          Margin="0,12,0,0"
                                          ItemsSource="{Binding ProposedFolders}"
                                          SelectedItem="{Binding SelectedProposedFolder}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserAddRows="False"
                                          HeadersVisibility="Column"
                                          SelectionMode="Single">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Proposed folder" Binding="{Binding DisplayName}" Width="*" />
                                        <DataGridTextColumn Header="Direct" Binding="{Binding DirectModCount}" Width="70" />
                                        <DataGridTextColumn Header="Child" Binding="{Binding DescendantModCount}" Width="70" />
                                    </DataGrid.Columns>
                                </DataGrid>

                                <WrapPanel Grid.Row="4"
                                           Margin="0,12,0,0">
                                    <Button Command="{Binding DeleteEmptyFolderCommand}" Content="Delete Empty Folder" MinWidth="145" Height="32" Margin="0,0,10,10" />
                                    <Button Command="{Binding UndoCommand}" Content="{Binding UndoDescription}" MinWidth="130" Height="32" Margin="0,0,10,10" />
                                    <Button Command="{Binding RedoCommand}" Content="{Binding RedoDescription}" MinWidth="130" Height="32" Margin="0,0,10,10" />
                                </WrapPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Column="4"
                                Background="White"
                                BorderBrush="#FFD9DFE7"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Mods"
                                           FontSize="18"
                                           FontWeight="SemiBold" />

                                <DataGrid Grid.Row="1"
                                          Margin="0,12,0,0"
                                          ItemsSource="{Binding FilteredMods}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          SelectionMode="Extended"
                                          behaviors:SelectedItemsBehavior.BoundSelectedItems="{Binding SelectedOrganizerMods}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Mod" Binding="{Binding Name}" Width="2*" IsReadOnly="True" />
                                        <DataGridTextColumn Header="Current folder" Binding="{Binding CurrentVirtualFolder}" Width="1.4*" IsReadOnly="True" />
                                        <DataGridTextColumn Header="Proposed folder" Binding="{Binding ProposedVirtualFolder, UpdateSourceTrigger=PropertyChanged}" Width="1.5*" />
                                        <DataGridTextColumn Header="Creator" Binding="{Binding EffectiveCreator, UpdateSourceTrigger=PropertyChanged}" Width="1.2*" />
                                        <DataGridTextColumn Header="Type" Binding="{Binding DetectedType, UpdateSourceTrigger=PropertyChanged}" Width="1.1*" />
                                        <DataGridCheckBoxColumn Header="Protected" Binding="{Binding Protected}" Width="95" />
                                        <DataGridTextColumn Header="Source" Binding="{Binding ProposalSource}" Width="110" IsReadOnly="True" />
                                    </DataGrid.Columns>
                                </DataGrid>

                                <WrapPanel Grid.Row="2"
                                           Margin="0,12,0,0">
                                    <Button Command="{Binding AssignSelectedToSelectedFolderCommand}" Content="Assign Selected" MinWidth="125" Height="34" Margin="0,0,10,10" />
                                    <Button Command="{Binding AssignAllVisibleToSelectedFolderCommand}" Content="Assign Visible" MinWidth="120" Height="34" Margin="0,0,10,10" />
                                    <Button Command="{Binding ResetSelectedToCurrentFolderCommand}" Content="Return Selected" MinWidth="125" Height="34" Margin="0,0,10,10" />
                                    <Button Command="{Binding ResetAllVisibleToCurrentFolderCommand}" Content="Return Visible" MinWidth="120" Height="34" Margin="0,0,10,10" />
                                    <Button Command="{Binding MarkSelectedProtectedCommand}" Content="Protect Selected" MinWidth="130" Height="34" Margin="0,0,10,10" />
                                    <Button Command="{Binding UnprotectSelectedCommand}" Content="Unprotect Selected" MinWidth="145" Height="34" Margin="0,0,10,10" />
                                </WrapPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Review Changes">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="White"
                            BorderBrush="#FFD9DFE7"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Review the proposed changes"
                                           FontSize="20"
                                           FontWeight="SemiBold" />
                                <TextBlock Margin="0,10,0,0"
                                           FontSize="16"
                                           TextWrapping="Wrap">
                                    <Run Text="{Binding ReviewChanged, Mode=OneWay}" />
                                    <Run Text=" mods will change, " />
                                    <Run Text="{Binding ReviewProtected, Mode=OneWay}" />
                                    <Run Text=" protected mods will remain unchanged, " />
                                    <Run Text="{Binding ReviewInvalid, Mode=OneWay}" />
                                    <Run Text=" invalid changes." />
                                </TextBlock>
                                <TextBlock Margin="0,10,0,0"
                                           Text="{Binding ApplyUnavailableReason}"
                                           Foreground="#FF556171"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Command="{Binding BackupAndApplyCommand}"
                                    Content="Backup and Apply"
                                    MinWidth="170"
                                    Height="42"
                                    VerticalAlignment="Top"
                                    FontWeight="SemiBold" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1"
                          Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="White"
                                BorderBrush="#FFD9DFE7"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18">
                            <StackPanel>
                                <TextBlock Text="Readiness"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Margin="0,12,0,0"
                                           Text="{Binding ApplyChecklist}"
                                           FontFamily="Consolas"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Background="White"
                                BorderBrush="#FFD9DFE7"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18">
                            <StackPanel>
                                <TextBlock Text="Latest result"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Margin="0,12,0,0"
                                           Text="{Binding DryRunStatus}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,10,0,0"
                                           Text="{Binding BackupStatus}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="2"
                            Margin="0,16,0,0"
                            Background="White"
                            BorderBrush="#FFD9DFE7"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="18">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Filter"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0" />
                                <ComboBox Width="180"
                                          SelectedValue="{Binding ReviewFilter}"
                                          SelectedValuePath="Content">
                                    <ComboBoxItem Content="All" />
                                    <ComboBoxItem Content="Changes only" />
                                    <ComboBoxItem Content="Needs Review" />
                                    <ComboBoxItem Content="Protected" />
                                    <ComboBoxItem Content="Invalid only" />
                                    <ComboBoxItem Content="Imported AI" />
                                    <ComboBoxItem Content="Manual" />
                                    <ComboBoxItem Content="Deterministic" />
                                    <ComboBoxItem Content="Unchanged" />
                                </ComboBox>
                                <Button Command="{Binding RefreshReviewCommand}"
                                        Content="Refresh"
                                        MinWidth="90"
                                        Height="32"
                                        Margin="10,0,0,0" />
                            </StackPanel>

                            <DataGrid Grid.Row="1"
                                      Margin="0,12,0,0"
                                      ItemsSource="{Binding ReviewRows}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Mod" Binding="{Binding ModName}" Width="2*" />
                                    <DataGridTextColumn Header="Current folder" Binding="{Binding CurrentVirtualFolder}" Width="1.5*" />
                                    <DataGridTextColumn Header="New folder" Binding="{Binding ProposedVirtualFolder}" Width="1.5*" />
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120" />
                                    <DataGridTextColumn Header="Proposal source" Binding="{Binding Source}" Width="130" />
                                    <DataGridTextColumn Header="Notes" Binding="{Binding Message}" Width="2*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Backups">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="White"
                            BorderBrush="#FFD9DFE7"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Restore a previous backup"
                                           FontSize="20"
                                           FontWeight="SemiBold" />
                                <TextBlock Margin="0,10,0,0"
                                           Text="{Binding Backups.StatusMessage}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,6,0,0"
                                           Text="{Binding RecoveryStatus}"
                                           Foreground="#FF556171"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <WrapPanel Grid.Column="1"
                                       VerticalAlignment="Top">
                                <Button Command="{Binding Backups.RefreshCommand}" Content="Refresh" MinWidth="90" Height="34" Margin="0,0,10,10" />
                                <Button Command="{Binding Backups.RollbackCommand}" Content="Restore Backup" MinWidth="130" Height="34" Margin="0,0,10,10" />
                                <Button Command="{Binding Backups.VerifyBackupCommand}" Content="Verify Backup" MinWidth="120" Height="34" Margin="0,0,10,10" />
                                <Button Command="{Binding Backups.OpenBackupFolderCommand}" Content="Open Backup Folder" MinWidth="150" Height="34" />
                            </WrapPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1"
                          Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="White"
                                BorderBrush="#FFD9DFE7"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18">
                            <DataGrid ItemsSource="{Binding Backups.Operations}"
                                      SelectedItem="{Binding Backups.SelectedOperation}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Date" Binding="{Binding CreatedAtUtc}" Width="1.3*" />
                                    <DataGridTextColumn Header="Changed mods" Binding="{Binding AffectedItems}" Width="90" />
                                    <DataGridTextColumn Header="Apply result" Binding="{Binding ApplyStatus}" Width="110" />
                                    <DataGridTextColumn Header="Backup" Binding="{Binding BackupVerified}" Width="80" />
                                    <DataGridTextColumn Header="Rollback" Binding="{Binding RollbackStatus}" Width="140" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <Border Grid.Column="2"
                                Background="White"
                                BorderBrush="#FFD9DFE7"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Selected backup"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Grid.Row="1"
                                           Margin="0,12,0,0"
                                           Text="{Binding Backups.SelectionSummary}"
                                           TextWrapping="Wrap" />
                                <TextBlock Grid.Row="2"
                                           Margin="0,12,0,0"
                                           Text="{Binding Backups.SelectedBackupAvailability}"
                                           Foreground="#FF556171"
                                           TextWrapping="Wrap" />
                                <DataGrid Grid.Row="3"
                                          Margin="0,12,0,0"
                                          ItemsSource="{Binding Backups.AffectedFiles}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserAddRows="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Target" Binding="{Binding TargetPath}" Width="2*" />
                                        <DataGridTextColumn Header="Backup file" Binding="{Binding RelativeBackupPath}" Width="1.2*" />
                                        <DataGridTextColumn Header="Type" Binding="{Binding Classification}" Width="90" />
                                        <DataGridTextColumn Header="JSON" Binding="{Binding JsonStatus}" Width="90" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="White"
                                BorderBrush="#FFD9DFE7"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18">
                            <StackPanel>
                                <TextBlock Text="Settings"
                                           FontSize="20"
                                           FontWeight="SemiBold" />
                                <CheckBox Margin="0,14,0,0"
                                          IsChecked="{Binding ShowAdvancedTools}"
                                          Content="Show advanced tools and diagnostics" />
                                <WrapPanel Margin="0,14,0,0">
                                    <Button Command="{Binding SaveSessionCommand}" Content="Save Session" MinWidth="120" Height="34" Margin="0,0,10,10" />
                                    <Button Command="{Binding ResumeLastSessionCommand}" Content="Resume Last Session" MinWidth="150" Height="34" Margin="0,0,10,10" />
                                    <Button Command="{Binding DiscardSessionCommand}" Content="Reset Saved Session" MinWidth="150" Height="34" Margin="0,0,10,10" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1"
                                Margin="0,16,0,0"
                                Background="White"
                                BorderBrush="#FFD9DFE7"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18">
                            <StackPanel>
                                <TextBlock Text="AI Proposal Import"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Margin="0,12,0,0"
                                           Text="{Binding AiImportStatus}"
                                           TextWrapping="Wrap" />
                                <WrapPanel Margin="0,12,0,0">
                                    <Button Command="{Binding CreateAiReviewPackageCommand}" Content="Export Inventory Package" MinWidth="165" Height="34" Margin="0,0,10,10" />
                                    <Button Command="{Binding ImportAiProposalCommand}" Content="Import Proposal JSON" MinWidth="155" Height="34" Margin="0,0,10,10" />
                                    <Button Command="{Binding OpenExportFolderCommand}" Content="Open Export Folder" MinWidth="145" Height="34" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2"
                                Margin="0,16,0,0"
                                Background="White"
                                BorderBrush="#FFD9DFE7"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18"
                                Visibility="{Binding ShowAdvancedTools, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="Advanced tools"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Margin="0,12,0,0"
                                           Text="{Binding InstallationValidationStatus}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,8,0,0"
                                           Text="{Binding ControlledTestStatus}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,8,0,0"
                                           Text="{Binding ControlledTestSelectionSummary}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,8,0,0"
                                           Text="{Binding DiagnosticStatus}"
                                           TextWrapping="Wrap" />
                                <WrapPanel Margin="0,14,0,0">
                                    <Button Command="{Binding ValidateInstallationCommand}" Content="Validate My Installation" MinWidth="160" Height="34" Margin="0,0,10,10" />
                                    <Button Command="{Binding CreateDryRunCommand}" Content="Create Dry Run" MinWidth="130" Height="34" Margin="0,0,10,10" />
                                    <Button Command="{Binding CreateBackupCommand}" Content="Create Backup" MinWidth="130" Height="34" Margin="0,0,10,10" />
                                    <Button Command="{Binding ApplyVirtualFolderChangesCommand}" Content="Apply Prepared Changes" MinWidth="165" Height="34" Margin="0,0,10,10" />
                                    <Button Command="{Binding ConfigureControlledTestCommand}" Content="Controlled Test Apply" MinWidth="160" Height="34" Margin="0,0,10,10" />
                                    <Button Command="{Binding ClearControlledTestCommand}" Content="Clear Controlled Test" MinWidth="160" Height="34" Margin="0,0,10,10" />
                                    <Button Command="{Binding CreateDiagnosticPackageCommand}" Content="Create Diagnostic Package" MinWidth="175" Height="34" />
                                </WrapPanel>
                                <WrapPanel Margin="0,4,0,0">
                                    <Button Command="{Binding ReverifyIncompleteOperationCommand}" Content="Re-verify Incomplete" MinWidth="165" Height="34" Margin="0,0,10,10" />
                                    <Button Command="{Binding ContinueIncompleteVerificationCommand}" Content="Continue Verification" MinWidth="165" Height="34" Margin="0,0,10,10" />
                                    <Button Command="{Binding RollbackIncompleteOperationCommand}" Content="Roll Back Incomplete" MinWidth="165" Height="34" Margin="0,0,10,10" />
                                    <Button Command="{Binding ViewIncompleteOperationCommand}" Content="Focus Incomplete Backup" MinWidth="170" Height="34" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="3"
                                Margin="0,16,0,0"
                                Background="White"
                                BorderBrush="#FFD9DFE7"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Activity log"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBox Grid.Row="1"
                                         Margin="0,12,0,0"
                                         Text="{Binding ActivityLog, Mode=OneWay}"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         MinHeight="220" />
                            </Grid>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#FFD9DFE7"
                BorderThickness="1,1,1,0"
                Padding="18,10">
            <TextBlock Text="{Binding ProgressMessage}"
                       Foreground="#FF245C9A"
                       TextWrapping="Wrap" />
        </Border>

        <Border Background="#99FFFFFF"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Width="360"
                    Padding="22"
                    Background="White"
                    BorderBrush="#FFD9DFE7"
                    BorderThickness="1"
                    CornerRadius="10"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Working..."
                               FontSize="22"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                    <TextBlock Margin="0,12,0,0"
                               Text="{Binding ProgressMessage}"
                               TextWrapping="Wrap"
                               TextAlignment="Center" />
                    <ProgressBar Margin="0,18,0,0"
                                 IsIndeterminate="True"
                                 Height="8" />
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>

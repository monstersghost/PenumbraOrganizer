<Window x:Class="PenumbraOrganizer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:behaviors="clr-namespace:PenumbraOrganizer.App.Behaviors"
        mc:Ignorable="d"
        Title="Penumbra Organizer"
        Height="860"
        Width="1380"
        MinHeight="740"
        MinWidth="1180"
        WindowStartupLocation="CenterScreen"
        Background="#FFF4F6F8">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#FFD9DFE7"
                BorderThickness="0,0,0,1"
                Padding="24,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Penumbra Organizer"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="#FF1C2633" />
                    <TextBlock Margin="0,6,0,0"
                               Text="Portable organizer for Penumbra virtual folders. Physical mod files stay exactly where they are."
                               Foreground="#FF556171"
                               TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Command="{Binding CancelBusyCommand}"
                            Content="{Binding BusyCancelText}"
                            MinWidth="125"
                            Height="36"
                            Margin="0,0,10,0"
                            Visibility="{Binding CanCancelBusy, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <Button Command="{Binding DetectCommand}"
                            Content="Find Penumbra"
                            MinWidth="125"
                            Height="36"
                            Margin="0,0,10,0" />
                    <Button Command="{Binding ScanCommand}"
                            Content="Scan My Mods"
                            MinWidth="130"
                            Height="36" />
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1"
                    Margin="20"
                    IsEnabled="{Binding IsNotBusy}">
            <TabItem Header="1. Scan">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Row="0"
                                Grid.Column="0"
                                Background="White"
                                BorderBrush="#FFD9DFE7"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="20">
                            <StackPanel>
                                <TextBlock Text="Ready to Scan"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           Foreground="#FF1C2633" />
                                <TextBlock Margin="0,12,0,0"
                                           Text="{Binding DetectionSummary}"
                                           FontSize="16"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,10,0,0"
                                           Text="{Binding CompatibilitySummary}"
                                           Foreground="#FF556171"
                                           TextWrapping="Wrap" />
                                <WrapPanel Margin="0,18,0,0">
                                    <Button Command="{Binding ScanCommand}"
                                            Content="Scan My Mods"
                                            MinWidth="150"
                                            Height="40"
                                            Margin="0,0,10,10"
                                            FontWeight="SemiBold" />
                                    <Button Command="{Binding CreateBackupCommand}"
                                            Content="Create Backup"
                                            MinWidth="150"
                                            Height="40"
                                            Margin="0,0,10,10" />
                                    <Button Command="{Binding DetectCommand}"
                                            Content="Find Penumbra Again"
                                            MinWidth="150"
                                            Height="40"
                                            Margin="0,0,10,10" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="0"
                                Grid.Column="2"
                                Background="White"
                                BorderBrush="#FFD9DFE7"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="20">
                            <StackPanel>
                                <TextBlock Text="Detected Paths"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Margin="0,12,0,0"
                                           Text="Penumbra state directory"
                                           Foreground="#FF556171" />
                                <TextBlock Text="{Binding PenumbraStateDirectory}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,12,0,0"
                                           Text="Mod library root"
                                           Foreground="#FF556171" />
                                <TextBlock Text="{Binding ModLibraryRoot}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,12,0,0"
                                           Text="Installed Penumbra version"
                                           Foreground="#FF556171" />
                                <TextBlock Text="{Binding InstalledPenumbraVersion}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1"
                                Grid.ColumnSpan="3"
                                Margin="0,18,0,0"
                                Background="#FFFDF6E7"
                                BorderBrush="#FFE9D5A1"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18"
                                Visibility="{Binding InstallationMissing, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="Automatic detection did not find Penumbra."
                                           FontWeight="SemiBold"
                                           Foreground="#FF7A5312" />
                                <TextBlock Margin="0,6,0,0"
                                           Text="Choose your Penumbra.json file manually if XIVLauncher is stored somewhere unusual."
                                           TextWrapping="Wrap" />
                                <WrapPanel Margin="0,14,0,0">
                                    <Button Command="{Binding ChoosePenumbraConfigCommand}"
                                            Content="Choose Penumbra.json"
                                            MinWidth="180"
                                            Height="36"
                                            Margin="0,0,10,0" />
                                    <TextBlock VerticalAlignment="Center"
                                               Text="{Binding ManualConfigPath}"
                                               Foreground="#FF556171"
                                               TextWrapping="Wrap" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="2"
                              Grid.ColumnSpan="3"
                              Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="White"
                                    BorderBrush="#FFD9DFE7"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="18">
                                <StackPanel>
                                    <TextBlock Text="Installed mods"
                                               Foreground="#FF556171" />
                                    <TextBlock Text="{Binding InstalledModCount}"
                                               FontSize="28"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Background="White"
                                    BorderBrush="#FFD9DFE7"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="18">
                                <StackPanel>
                                    <TextBlock Text="Protected mods"
                                               Foreground="#FF556171" />
                                    <TextBlock Text="{Binding ProtectedModCount}"
                                               FontSize="28"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="4"
                                    Background="White"
                                    BorderBrush="#FFD9DFE7"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="18">
                                <StackPanel>
                                    <TextBlock Text="Collections / warnings"
                                               Foreground="#FF556171" />
                                    <TextBlock FontSize="28"
                                               FontWeight="SemiBold">
                                        <Run Text="{Binding CollectionCount, Mode=OneWay}" />
                                        <Run Text=" / " />
                                        <Run Text="{Binding WarningCount, Mode=OneWay}" />
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Grid.Row="3"
                                Grid.ColumnSpan="3"
                                Margin="0,18,0,0"
                                Background="White"
                                BorderBrush="#FFD9DFE7"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Scan Warnings"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <ListBox Grid.Row="1"
                                         Margin="0,12,0,0"
                                         ItemsSource="{Binding ScanWarnings}"
                                         MinHeight="220" />
                            </Grid>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="2. Export / 3. Import">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="White"
                                BorderBrush="#FFD9DFE7"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Export a simple workbook"
                                               FontSize="20"
                                               FontWeight="SemiBold" />
                                    <TextBlock Margin="0,10,0,0"
                                               Text="Scan your library, export one workbook, edit mod type, protected, and destination, import it back, then continue to Review and Apply."
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,10,0,0"
                                               Text="{Binding WorkbookStatus}"
                                               Foreground="#FF556171"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding WorkbookImportStatus}"
                                               Foreground="#FF245C9A"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <WrapPanel Grid.Column="1"
                                           VerticalAlignment="Top">
                                    <Button Command="{Binding ExportWorkbookCommand}"
                                            Content="Export Workbook"
                                            MinWidth="150"
                                            Height="38"
                                            Margin="0,0,10,10"
                                            FontWeight="SemiBold" />
                                    <Button Command="{Binding OpenWorkbookCommand}"
                                            Content="Open Workbook"
                                            MinWidth="140"
                                            Height="38"
                                            Margin="0,0,10,10" />
                                    <Button Command="{Binding OpenWorkbookFolderCommand}"
                                            Content="Open Export Folder"
                                            MinWidth="150"
                                            Height="38"
                                            Margin="0,0,10,10" />
                                    <Button Command="{Binding ImportWorkbookCommand}"
                                            Content="Import Workbook"
                                            MinWidth="150"
                                            Height="38" />
                                </WrapPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1"
                                Margin="0,16,0,0"
                                Background="White"
                                BorderBrush="#FFD9DFE7"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18">
                            <StackPanel>
                                <TextBlock Text="Export Strategy"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Margin="0,8,0,0"
                                           Text="This only fills the initial mod type and destination suggestions in the workbook. You can edit both before importing."
                                           TextWrapping="Wrap"
                                           Foreground="#FF556171" />
                                <WrapPanel Margin="0,14,0,0">
                                    <Button Command="{Binding SelectStrategyCommand}" CommandParameter="Blank Template" Content="Blank Template" MinWidth="145" Height="34" Margin="0,0,10,10" />
                                    <Button Command="{Binding SelectStrategyCommand}" CommandParameter="Type" Content="Type" MinWidth="95" Height="34" Margin="0,0,10,10" />
                                    <Button Command="{Binding SelectStrategyCommand}" CommandParameter="Type / Author" Content="Type / Author" MinWidth="130" Height="34" Margin="0,0,10,10" />
                                    <Button Command="{Binding SelectStrategyCommand}" CommandParameter="Author / Type" Content="Author / Type" MinWidth="130" Height="34" Margin="0,0,10,10" />
                                    <Button Command="{Binding SelectStrategyCommand}" CommandParameter="Keep Current" Content="Keep Current" MinWidth="125" Height="34" Margin="0,0,10,10" />
                                </WrapPanel>
                                <TextBlock Margin="0,8,0,0"
                                           Text="{Binding SelectedStrategy, StringFormat=Selected strategy: {0}}"
                                           Foreground="#FF556171" />
                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="2"
                              Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="White"
                                    BorderBrush="#FFD9DFE7"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="18">
                                <StackPanel>
                                    <TextBlock Text="Workbook Columns"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock Margin="0,12,0,0"
                                               Text="# | mod name | author | current folder | mod type | protected | destination"
                                               FontFamily="Consolas"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="Editable workbook columns are shaded green: mod type, protected, and destination."
                                               TextWrapping="Wrap"
                                               Foreground="#FF245C9A" />
                                    <TextBlock Margin="0,12,0,0"
                                               Text="Blank destination rule: leave destination empty to keep the current folder unchanged."
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,12,0,0"
                                               Text="Review rule: use mod type Review or destination 7/Review when a row still needs attention."
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,12,0,0"
                                               Text="A hidden locked internal key is used on import. The visible # column is only for row numbering."
                                               TextWrapping="Wrap"
                                               Foreground="#FF556171" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Background="White"
                                    BorderBrush="#FFD9DFE7"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="18">
                                <StackPanel>
                                    <TextBlock Text="Category Shorthand"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock Margin="0,12,0,0"
                                               Text="{Binding WorkbookCategorySummary}"
                                               FontFamily="Consolas"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,12,0,0"
                                               Text="Example: 1/Bizu becomes Clothing/Bizu. Safe relative paths like Bizu/1 are also allowed."
                                               TextWrapping="Wrap"
                                               Foreground="#FF556171" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Grid.Row="3"
                                Margin="0,16,0,0"
                                Background="White"
                                BorderBrush="#FFD9DFE7"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18">
                            <StackPanel>
                                <TextBlock Text="What happens on import"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Margin="0,12,0,0"
                                           Text="The app validates workbook keys, duplicate rows, malformed paths, traversal such as ../, and stale exports before updating the review list."
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,10,0,0"
                                           Text="After a successful import, go to Review and Apply to inspect the diff. Backup and Apply still creates a fresh verified backup immediately before writing."
                                           TextWrapping="Wrap"
                                           Foreground="#FF556171" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="4. Review / 5. Apply">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="White"
                            BorderBrush="#FFD9DFE7"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Review the proposed changes"
                                           FontSize="20"
                                           FontWeight="SemiBold" />
                                <TextBlock Margin="0,10,0,0"
                                           FontSize="16"
                                           TextWrapping="Wrap">
                                    <Run Text="{Binding ReviewMoveRows, Mode=OneWay}" />
                                    <Run Text=" moves, " />
                                    <Run Text="{Binding ReviewProtectionChanges, Mode=OneWay}" />
                                    <Run Text=" protection changes, " />
                                    <Run Text="{Binding ReviewWarnings, Mode=OneWay}" />
                                    <Run Text=" warning rows, " />
                                    <Run Text="{Binding ReviewNeedsReview, Mode=OneWay}" />
                                    <Run Text=" Review rows, " />
                                    <Run Text="{Binding ReviewSkipped, Mode=OneWay}" />
                                    <Run Text=" skipped, " />
                                    <Run Text="{Binding ReviewUnchanged, Mode=OneWay}" />
                                    <Run Text=" unchanged, " />
                                    <Run Text="{Binding ReviewProtected, Mode=OneWay}" />
                                    <Run Text=" protected rows, " />
                                    <Run Text="{Binding ReviewInvalid, Mode=OneWay}" />
                                    <Run Text=" invalid changes." />
                                </TextBlock>
                                <TextBlock Margin="0,10,0,0"
                                           Text="{Binding ApplyUnavailableReason}"
                                           Foreground="#FF556171"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Command="{Binding BackupAndApplyCommand}"
                                    Content="Backup and Apply"
                                    MinWidth="170"
                                    Height="42"
                                    VerticalAlignment="Top"
                                    FontWeight="SemiBold" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1"
                          Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="White"
                                BorderBrush="#FFD9DFE7"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18">
                            <StackPanel>
                                <TextBlock Text="Readiness"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Margin="0,12,0,0"
                                           Text="{Binding ApplyChecklist}"
                                           FontFamily="Consolas"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Background="White"
                                BorderBrush="#FFD9DFE7"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18">
                            <StackPanel>
                                <TextBlock Text="Latest result"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Margin="0,12,0,0"
                                           Text="{Binding DryRunStatus}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,10,0,0"
                                           Text="{Binding BackupStatus}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="2"
                            Margin="0,16,0,0"
                            Background="White"
                            BorderBrush="#FFD9DFE7"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="18">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Filter"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0" />
                                <ComboBox Width="180"
                                          SelectedValue="{Binding ReviewFilter}"
                                          SelectedValuePath="Content">
                                    <ComboBoxItem Content="All" />
                                    <ComboBoxItem Content="Changes only" />
                                    <ComboBoxItem Content="Warnings / Needs Review" />
                                    <ComboBoxItem Content="Needs Review" />
                                    <ComboBoxItem Content="Skipped" />
                                    <ComboBoxItem Content="Protected" />
                                    <ComboBoxItem Content="Invalid only" />
                                    <ComboBoxItem Content="Unchanged" />
                                </ComboBox>
                                <Button Command="{Binding RefreshReviewCommand}"
                                        Content="Refresh"
                                        MinWidth="90"
                                        Height="32"
                                        Margin="10,0,0,0" />
                            </StackPanel>

                            <DataGrid Grid.Row="1"
                                      Margin="0,12,0,0"
                                      ItemsSource="{Binding ReviewRows}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Mod" Binding="{Binding ModName}" Width="2*" />
                                    <DataGridTextColumn Header="Current folder" Binding="{Binding CurrentVirtualFolder}" Width="1.5*" />
                                    <DataGridTextColumn Header="New folder" Binding="{Binding ProposedVirtualFolder}" Width="1.5*" />
                                    <DataGridTextColumn Header="Change" Binding="{Binding ChangeSummary}" Width="1.05*" />
                                    <DataGridTextColumn Header="Type" Binding="{Binding TypeLabel}" Width="1.05*" />
                                    <DataGridCheckBoxColumn Header="Protected" Binding="{Binding Protected}" Width="95" />
                                    <DataGridTextColumn Header="Review status" Binding="{Binding StatusLabel}" Width="1.05*" />
                                    <DataGridTextColumn Header="Proposal source" Binding="{Binding Source}" Width="130" />
                                    <DataGridTextColumn Header="Notes" Binding="{Binding Message}" Width="2*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="6. Restore">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="White"
                            BorderBrush="#FFD9DFE7"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Restore a previous backup"
                                           FontSize="20"
                                           FontWeight="SemiBold" />
                                <TextBlock Margin="0,10,0,0"
                                           Text="{Binding Backups.StatusMessage}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,6,0,0"
                                           Text="{Binding RecoveryStatus}"
                                           Foreground="#FF556171"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <WrapPanel Grid.Column="1"
                                       VerticalAlignment="Top">
                                <Button Command="{Binding CreateBackupCommand}" Content="Create Backup Now" MinWidth="145" Height="34" Margin="0,0,10,10" />
                                <Button Command="{Binding Backups.RefreshCommand}" Content="Refresh" MinWidth="90" Height="34" Margin="0,0,10,10" />
                                <Button Command="{Binding Backups.RollbackCommand}" Content="Restore Backup" MinWidth="130" Height="34" Margin="0,0,10,10" />
                                <Button Command="{Binding Backups.VerifyBackupCommand}" Content="Verify Backup" MinWidth="120" Height="34" Margin="0,0,10,10" />
                                <Button Command="{Binding Backups.OpenBackupFolderCommand}" Content="Open Backup Folder" MinWidth="150" Height="34" />
                            </WrapPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1"
                          Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="White"
                                BorderBrush="#FFD9DFE7"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18">
                            <DataGrid ItemsSource="{Binding Backups.Operations}"
                                      SelectedItem="{Binding Backups.SelectedOperation}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Date" Binding="{Binding CreatedAtUtc}" Width="1.3*" />
                                    <DataGridTextColumn Header="Kind" Binding="{Binding OperationKind}" Width="120" />
                                    <DataGridTextColumn Header="Changed mods" Binding="{Binding AffectedItems}" Width="90" />
                                    <DataGridTextColumn Header="Apply result" Binding="{Binding ApplyStatus}" Width="110" />
                                    <DataGridTextColumn Header="Backup" Binding="{Binding BackupVerified}" Width="80" />
                                    <DataGridTextColumn Header="Rollback" Binding="{Binding RollbackStatus}" Width="140" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <Border Grid.Column="2"
                                Background="White"
                                BorderBrush="#FFD9DFE7"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Selected backup"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Grid.Row="1"
                                           Margin="0,12,0,0"
                                           Text="{Binding Backups.SelectionSummary}"
                                           TextWrapping="Wrap" />
                                <TextBlock Grid.Row="2"
                                           Margin="0,12,0,0"
                                           Text="{Binding Backups.SelectedBackupAvailability}"
                                           Foreground="#FF556171"
                                           TextWrapping="Wrap" />
                                <DataGrid Grid.Row="3"
                                          Margin="0,12,0,0"
                                          ItemsSource="{Binding Backups.AffectedFiles}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserAddRows="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Target" Binding="{Binding TargetPath}" Width="2*" />
                                        <DataGridTextColumn Header="Backup file" Binding="{Binding RelativeBackupPath}" Width="1.2*" />
                                        <DataGridTextColumn Header="Type" Binding="{Binding Classification}" Width="90" />
                                        <DataGridTextColumn Header="JSON" Binding="{Binding JsonStatus}" Width="90" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="White"
                                BorderBrush="#FFD9DFE7"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18">
                            <StackPanel>
                                <TextBlock Text="Settings"
                                           FontSize="20"
                                           FontWeight="SemiBold" />
                                <WrapPanel Margin="0,14,0,0">
                                    <Button Command="{Binding SaveSessionCommand}" Content="Save Session" MinWidth="120" Height="34" Margin="0,0,10,10" />
                                    <Button Command="{Binding ResumeLastSessionCommand}" Content="Resume Last Session" MinWidth="150" Height="34" Margin="0,0,10,10" />
                                    <Button Command="{Binding DiscardSessionCommand}" Content="Reset Saved Session" MinWidth="150" Height="34" Margin="0,0,10,10" />
                                    <Button Command="{Binding OpenLogsFolderCommand}" Content="Open Logs Folder" MinWidth="140" Height="34" Margin="0,0,10,10" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1"
                                Margin="0,16,0,0"
                                Background="White"
                                BorderBrush="#FFD9DFE7"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Activity log"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBox Grid.Row="1"
                                         Margin="0,12,0,0"
                                         Text="{Binding ActivityLog, Mode=OneWay}"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         MinHeight="220" />
                            </Grid>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#FFD9DFE7"
                BorderThickness="1,1,1,0"
                Padding="18,10">
            <TextBlock Text="{Binding ProgressMessage}"
                       Foreground="#FF245C9A"
                       TextWrapping="Wrap" />
        </Border>

        <Border Background="#99FFFFFF"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Width="360"
                    Padding="22"
                    Background="White"
                    BorderBrush="#FFD9DFE7"
                    BorderThickness="1"
                    CornerRadius="10"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Working..."
                               FontSize="22"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                    <TextBlock Margin="0,12,0,0"
                               Text="{Binding ProgressMessage}"
                               TextWrapping="Wrap"
                               TextAlignment="Center" />
                    <ProgressBar Margin="0,18,0,0"
                                 IsIndeterminate="True"
                                 Height="8" />
                    <Button Command="{Binding CancelBusyCommand}"
                            Content="{Binding BusyCancelText}"
                            MinWidth="130"
                            Height="36"
                            Margin="0,18,0,0"
                            HorizontalAlignment="Center"
                            Visibility="{Binding CanCancelBusy, Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>

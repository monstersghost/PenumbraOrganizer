<Window x:Class="PenumbraOrganizer.App.Dialogs.WorkflowIssueDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Width="700"
        Height="500"
        MinWidth="620"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="#FFF4F6F8">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="{Binding Heading}"
                       FontSize="22"
                       FontWeight="SemiBold" />
            <TextBlock Margin="0,10,0,0"
                       Text="{Binding Summary}"
                       TextWrapping="Wrap" />
            <TextBlock Margin="0,10,0,0"
                       Text="{Binding SeverityLabel}"
                       FontWeight="SemiBold"
                       Foreground="{Binding SeverityBrush}" />
            <TextBlock Margin="0,6,0,0"
                       Text="{Binding WriteStateLabel}"
                       Foreground="#FF556171"
                       TextWrapping="Wrap" />
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,16,0,0"
                Background="White"
                BorderBrush="#FFD9DFE7"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="Affected rows / mods"
                           FontWeight="SemiBold" />
                <TextBlock Grid.Row="1"
                           Margin="0,8,0,0"
                           Text="{Binding AffectedSummary}"
                           TextWrapping="Wrap" />
            </Grid>
        </Border>

        <Expander Grid.Row="2"
                  Margin="0,16,0,0"
                  Header="Technical details"
                  IsExpanded="False">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Margin="0,0,0,10"
                           Text="{Binding LogLocationLabel}"
                           Foreground="#FF556171"
                           TextWrapping="Wrap" />
                <TextBox Text="{Binding TechnicalDetails, Mode=OneWay}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto" />
            </DockPanel>
        </Expander>

        <WrapPanel Grid.Row="3"
                   Margin="0,16,0,0"
                   HorizontalAlignment="Right">
            <Button Content="{Binding ReviewLabel}"
                    MinWidth="150"
                    Height="34"
                    Margin="0,0,10,0"
                    Visibility="{Binding ReviewVisible}"
                    Click="Review_Click" />
            <Button Content="{Binding SkipLabel}"
                    MinWidth="200"
                    Height="34"
                    Margin="0,0,10,0"
                    Visibility="{Binding SkipVisible}"
                    Click="Skip_Click" />
            <Button Content="{Binding ContinueLabel}"
                    MinWidth="130"
                    Height="34"
                    Margin="0,0,10,0"
                    Visibility="{Binding ContinueVisible}"
                    Click="Continue_Click" />
            <Button Content="Copy Details"
                    MinWidth="110"
                    Height="34"
                    Margin="0,0,10,0"
                    Click="CopyDetails_Click" />
            <Button Content="Open Logs Folder"
                    MinWidth="130"
                    Height="34"
                    Margin="0,0,10,0"
                    Click="OpenLogsFolder_Click" />
            <Button Content="{Binding CancelLabel}"
                    MinWidth="90"
                    Height="34"
                    IsDefault="True"
                    Click="Cancel_Click" />
        </WrapPanel>
    </Grid>
</Window>

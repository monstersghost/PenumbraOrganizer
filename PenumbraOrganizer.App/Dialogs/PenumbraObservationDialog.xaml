<Window x:Class="PenumbraOrganizer.App.Dialogs.PenumbraObservationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Penumbra UI Observation"
        Height="300"
        Width="620"
        MinHeight="280"
        MinWidth="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="HeaderText"
                   Text="Open Penumbra and check whether the new virtual folder appears."
                   FontSize="20"
                   FontWeight="SemiBold"
                   TextWrapping="Wrap" />

        <TextBlock x:Name="DisclaimerText"
                   Grid.Row="1"
                   Margin="0,16,0,16"
                   Text="This observation is stored as diagnostic evidence only. It does not prove that organization.json must be written, and it does not change the write path."
                   TextWrapping="Wrap" />

        <UniformGrid Grid.Row="2" Columns="2" Rows="2">
            <Button x:Name="AppearedImmediatelyButton" Content="Appeared immediately" Margin="0,0,10,10" Height="40" Click="AppearedImmediately_Click" />
            <Button x:Name="AppearedAfterReloadButton" Content="Appeared after reload/restart" Margin="0,0,0,10" Height="40" Click="AppearedAfterReload_Click" />
            <Button x:Name="DidNotAppearButton" Content="Did not appear" Margin="0,0,10,0" Height="40" Click="DidNotAppear_Click" />
            <Button x:Name="NotCheckedYetButton" Content="I have not checked yet" Height="40" Click="NotCheckedYet_Click" />
        </UniformGrid>
    </Grid>
</Window>

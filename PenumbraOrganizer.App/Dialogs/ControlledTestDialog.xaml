<Window x:Class="PenumbraOrganizer.App.Dialogs.ControlledTestDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Controlled Test Apply"
        Height="720"
        Width="1060"
        MinHeight="640"
        MinWidth="920"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Controlled Test Apply" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Margin="0,8,0,0"
                       Text="Choose a tiny set of mods for the first live test. Physical mod folders will not move. Protected, ambiguous, and unsupported mods stay unavailable."
                       TextWrapping="Wrap" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,18,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Test Folder Name" FontWeight="SemiBold" />
                <TextBox Margin="0,8,0,0"
                         Text="{Binding TestFolderName, UpdateSourceTrigger=PropertyChanged}"
                         Height="32"
                         Padding="8,4" />
                <TextBlock Margin="0,10,0,0"
                           Text="{Binding SelectionStatus}"
                           Foreground="#FF245C9A"
                           TextWrapping="Wrap" />
            </StackPanel>

            <Border Grid.Column="2"
                    Background="#FFF8FAFC"
                    BorderBrush="#FFE2E5EA"
                    BorderThickness="1"
                    Padding="12">
                <StackPanel>
                    <TextBlock Text="Advanced Details" FontWeight="SemiBold" />
                    <TextBox Margin="0,8,0,0"
                             Text="{Binding SelectedCandidateDetails}"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             MinHeight="110" />
                </StackPanel>
            </Border>
        </Grid>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Candidates}"
                  SelectedItem="{Binding SelectedCandidate}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="False"
                  EnableRowVirtualization="True"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="Select" Binding="{Binding Selected, UpdateSourceTrigger=PropertyChanged}" Width="70" />
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120" IsReadOnly="True" />
                <DataGridTextColumn Header="Mod" Binding="{Binding ModName}" Width="1.8*" IsReadOnly="True" />
                <DataGridTextColumn Header="Current Folder" Binding="{Binding CurrentVirtualFolder}" Width="1.5*" IsReadOnly="True" />
                <DataGridTextColumn Header="Current Proposal" Binding="{Binding CurrentProposedFolder}" Width="1.5*" IsReadOnly="True" />
                <DataGridTextColumn Header="Test Folder" Binding="{Binding ProposedTestFolder}" Width="1.5*" IsReadOnly="True" />
                <DataGridTextColumn Header="Physical Path" Binding="{Binding PhysicalDirectory}" Width="2.4*" IsReadOnly="True" />
                <DataGridTextColumn Header="Why" Binding="{Binding StatusMessage}" Width="2*" IsReadOnly="True" />
            </DataGrid.Columns>
        </DataGrid>

        <DockPanel Grid.Row="3" Margin="0,14,0,0">
            <TextBlock DockPanel.Dock="Left"
                       VerticalAlignment="Center"
                       Text="{Binding FooterStatus}"
                       TextWrapping="Wrap" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="Cancel"
                        Width="120"
                        Height="34"
                        Margin="0,0,10,0"
                        Click="Cancel_Click" />
                <Button Content="Create Controlled Dry Run"
                        Width="190"
                        Height="34"
                        Click="Confirm_Click" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>

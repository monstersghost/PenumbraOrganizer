<Window x:Class="PenumbraOrganizer.App.Dialogs.AdvancedCleanupRiskDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Advanced Cleanup: At Your Own Risk"
        Height="420"
        Width="640"
        MinHeight="400"
        MinWidth="580"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Advanced Cleanup removes the per-Apply safety cap"
                   FontSize="20"
                   FontWeight="SemiBold"
                   TextWrapping="Wrap" />

        <TextBlock Grid.Row="1" Margin="0,16,0,16" TextWrapping="Wrap">
            <Run Text="Folder Cleanup normally limits each Apply to 3 pruned folders while this feature is still being validated on real installs. Enabling Advanced Cleanup removes that limit for this session, so Select All can prune every orphaned folder it finds in a single Apply." />
            <LineBreak /><LineBreak />
            <Run Text="This write path has only been validated on a small number of real installs so far. A much larger, untested batch carries more risk if something is wrong." />
            <LineBreak /><LineBreak />
            <Run Text="Before continuing, make sure you have a manual backup of your Penumbra config folder outside this app (see the how-to-use guide's manual backup steps). This setting resets every time you restart the app." />
        </TextBlock>

        <CheckBox x:Name="AcknowledgeCheckBox"
                  Grid.Row="2"
                  Content="I understand the risk and want to enable Advanced Cleanup for this session."
                  Margin="0,0,0,14"
                  Checked="AcknowledgeCheckBox_Changed"
                  Unchecked="AcknowledgeCheckBox_Changed" />

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="100" Height="34" Margin="0,0,10,0" Click="Cancel_Click" />
            <Button x:Name="ConfirmButton" Content="Enable Advanced Cleanup" Width="190" Height="34" IsEnabled="False" Click="Confirm_Click" />
        </StackPanel>
    </Grid>
</Window>

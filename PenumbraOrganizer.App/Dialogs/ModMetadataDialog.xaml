<Window x:Class="PenumbraOrganizer.App.Dialogs.ModMetadataDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Mod Metadata"
        Height="640"
        Width="560"
        MinHeight="560"
        MinWidth="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Edit Mod Metadata" FontSize="20" FontWeight="SemiBold" />
            <TextBlock Margin="0,6,0,0"
                       Text="Changes are staged into your review. Nothing is written to Penumbra until you Backup and Apply. Author fields update meta.json; favorite, local tags, and note update your per-user mod data."
                       TextWrapping="Wrap"
                       Foreground="#FF55606E" />
            <TextBlock Margin="0,8,0,0" Text="{Binding StableScanId, StringFormat='Mod folder: {0}'}" Foreground="#FF55606E" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" Margin="0,14,0,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Author metadata (meta.json)" FontWeight="SemiBold" Margin="0,0,0,6" />

                <TextBlock Text="Name" />
                <TextBox Margin="0,4,0,10" Padding="6,4" Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="Author" />
                <TextBox Margin="0,4,0,10" Padding="6,4" Text="{Binding EditAuthor, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="Version" />
                <TextBox Margin="0,4,0,10" Padding="6,4" Text="{Binding EditVersion, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="Website" />
                <TextBox Margin="0,4,0,10" Padding="6,4" Text="{Binding EditWebsite, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="Mod tags (comma-separated)" />
                <TextBox Margin="0,4,0,10" Padding="6,4" Text="{Binding EditModTagsText, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="Description" />
                <TextBox Margin="0,4,0,14"
                         Padding="6,4"
                         Text="{Binding EditDescription, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         MinHeight="64" />

                <TextBlock Text="Local data (your private mod_data)" FontWeight="SemiBold" Margin="0,4,0,6" />

                <CheckBox Margin="0,4,0,10" Content="Favorite" IsChecked="{Binding Favorite}" />

                <TextBlock Text="Local tags (comma-separated)" />
                <TextBox Margin="0,4,0,10" Padding="6,4" Text="{Binding EditLocalTagsText, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="Note" />
                <TextBox Margin="0,4,0,4"
                         Padding="6,4"
                         Text="{Binding EditNote, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         MinHeight="64" />
            </StackPanel>
        </ScrollViewer>

        <DockPanel Grid.Row="2" Margin="0,14,0,0">
            <TextBlock DockPanel.Dock="Left"
                       VerticalAlignment="Center"
                       Foreground="#FF245C9A"
                       Text="{Binding MetadataSummary, StringFormat='Pending changes: {0}'}" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="Cancel" Width="110" Height="34" Margin="0,0,10,0" IsCancel="True" Click="Cancel_Click" />
                <Button Content="Save Changes" Width="140" Height="34" IsDefault="True" Click="Confirm_Click" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
